Options -Indexes
Options +FollowSymLinks

RewriteEngine On

# Force HTTPS (uncomment on AWS after SSL is set up)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block access to sensitive files
<FilesMatch "(^\.env|\.env\..*|composer\.(json|lock)|\.git)">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to debug/test/migration scripts
<FilesMatch "(debug|test-|migrate_|seed_|check_|fix_|setup-|setup_|deploy_|create-manager)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block direct access to sensitive API files
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>
<Files "session.php">
    Order allow,deny
    Deny from all
</Files>
<Files "access-control.php">
    Order allow,deny
    Deny from all
</Files>

# Set default charset
AddDefaultCharset UTF-8
